APP_NAME="Kashtre Calling Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://calling.yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Hostinger production database
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_calling_db
DB_USERNAME=your_calling_user
DB_PASSWORD=your_calling_password

# Must match CALLING_SERVICE_SYNC_SECRET in the main Kashtre app
CALLING_SERVICE_SYNC_SECRET=replace_with_a_shared_random_secret

# Optional TTS integration
ELEVENLABS_API_KEY=
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1
ELEVENLABS_TIMEOUT=30

# Keep production simple on shared hosting
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
